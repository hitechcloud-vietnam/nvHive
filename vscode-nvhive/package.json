{
  "name": "nvhive",
  "displayName": "nvHive AI Agent",
  "description": "Multi-LLM AI agent with smart team assembly, code review, and test generation",
  "version": "0.1.0",
  "publisher": "nvhive",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "nvhive.agent", "title": "Run Agent Task", "category": "nvHive" },
      { "command": "nvhive.review", "title": "Code Review", "category": "nvHive" },
      { "command": "nvhive.testgen", "title": "Generate Tests", "category": "nvHive" },
      { "command": "nvhive.explain", "title": "Explain Code", "category": "nvHive" },
      { "command": "nvhive.council", "title": "Ask Council", "category": "nvHive" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nvhive",
          "title": "nvHive",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "nvhive": [
        { "id": "nvhive.agentPanel", "name": "Agent" },
        { "id": "nvhive.advisorsPanel", "name": "Advisors" }
      ]
    },
    "configuration": {
      "title": "nvHive",
      "properties": {
        "nvhive.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the nvHive API server"
        },
        "nvhive.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start nvh serve if API is not running"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
